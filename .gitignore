master/*_pb2_grpc.py
master/*_pb2.pyi
client/*_pb2.py
client/*_pb2_grpc.py
# C++ stubs
chunkserver/*.pb.cc
chunkserver/*.pb.h
chunkserver/*.grpc.pb.cc
chunkserver/*.grpc.pb.h
chunkserver/*_pb2.py
chunkserver/*_pb2_grpc.py
chunkserver/*_pb2.pyi
.pytest_cache/

# Local data directories (so you don't commit giant chunks)
/data/
/chunks/

