# Python environment & cache
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
venv/
.env

# C++ & CMake Build Artifacts
build/
*.o
*.a
CMakeCache.txt
CMakeFiles/
Makefile
cmake_install.cmake

# gRPC Auto-generated Stubs 
# (These are generated inside the Docker containers during the build process)
*_pb2.py
*_pb2_grpc.py
*_pb2.pyi
*.pb.cc
*.pb.h
*.grpc.pb.cc
*.grpc.pb.h

# GFS Data, Trash, and Logs 
# (Never commit actual chunk data or master oplogs)
/chunks/
/data/
*.log
.trash/

# Benchmark & Test Outputs 
# (Prevents massive 3MB/5MB files from bloating your git history)
*.bin
*.dat
test_file_*.txt
concurrent_append_*.bin
fault_test_*.bin

# Random Scratch / Temporary Files
scratch.py
test.py
temp/
tmp/

# OS generated files
.DS_Store
Thumbs.db


.vscode
